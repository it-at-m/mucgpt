# Assistant Service Configuration
# This file provides an example YAML configuration for the MUCGPT assistant service.
# You can use this instead of environment variables.
#
# Priority order (highest to lowest):
# 1. Environment variables (MUCGPT_ASSISTANT_* for top-level, MUCGPT_ASSISTANT_<SECTION>__<FIELD> for nested)
# 2. YAML configuration file (this file, when named config.yaml)
# 3. .env file
#
# Note: Because case_sensitive=False in settings, use UPPERCASE field names in YAML
# Nested env vars use __ (double underscore) as delimiter, e.g. MUCGPT_ASSISTANT_DB__HOST

# Database settings (nested under DB key)
DB:
  HOST: "postgres"
  PORT: 5432
  NAME: "postgres"
  USER: "admin"
  PASSWORD: "admin"
  # SCHEMA: "myschema"  # Optional: restrict to a specific PostgreSQL schema (sets search_path)

# Backend settings
UNAUTHORIZED_USER_REDIRECT_URL: ""
LOG_CONFIG: "app/logconf.yaml"
# Optional: if true, assistant read endpoints repopulate missing owner cache fields from LDAP
OWNER_CACHE_REFRESH_ON_READ: false

# SSO Settings (nested under SSO key)
SSO:
  ROLE: "lhm-ab-mucgpt-user"

# Redis Settings (nested under REDIS key)
REDIS:
  HOST: "valkey"
  PORT: 6379
  USERNAME: "default"
  PASSWORD: "password"

# LDAP Settings (nested under LDAP key)
LDAP:
  ENABLED: true
  HOST: "<ldap-host>"
  PORT: 636
  USE_SSL: true
  START_TLS: false
  VERIFY_SSL: true
  CA_CERT_FILE: null
  BIND_DN: "<bind-dn>"
  BIND_PASSWORD: "<bind-password>"
  SEARCH_BASE: "o=Landeshauptstadt München,c=de"
  SEARCH_FILTER: "(objectClass=organizationalUnit)"
  DISPLAY_ATTRIBUTE: "ou"
  PARENT_ATTRIBUTE: null
  IGNORED_OU_PREFIXES: ["_"]
  IGNORED_OU_SUFFIXES: ["-xxx"]
  # Keep specific OUs even when they match IGNORED_OU_PREFIXES / IGNORED_OU_SUFFIXES.
  # Matching is done against lhmOUShortname (case-insensitive).
  # Example: keep OU "_Hidden" if its lhmOUShortname is "FBM".
  IGNORED_OU_SHORTNAME_EXCEPTIONS: ["FBM", "KVR-IT"]
  CACHE_TTL: 1209600 # 14 days in seconds
  PAGE_SIZE: 500
  # Dedicated user/person lookup settings (independent from OU filtering/required-attributes)
  USER_SEARCH_BASE: "o=Landeshauptstadt München,c=de"
  USER_SEARCH_FILTER: "(objectClass=person)"
  USER_SEARCH_ATTRIBUTES: ["givenName", "sn", "mail", "lhmobjectid", "organizationalunit"]
  USER_ID_ATTRIBUTE: "lhmobjectid"
  USER_GIVEN_NAME_ATTRIBUTE: "givenName"
  USER_SURNAME_ATTRIBUTE: "sn"
  USER_MAIL_ATTRIBUTE: "mail"
  USER_ORGANIZATIONAL_UNIT_ATTRIBUTE: "organizationalunit"
