# Core Service Configuration for Docker Compose Stack
# This file is mounted into the core-service container at /app/config.yaml
#
# Note: Use UPPERCASE field names because case_sensitive=False in settings

# General settings
VERSION: "0.7.1"
LOG_CONFIG: "logconf.yaml"

# Frontend settings
ENV_NAME: "MUCGPT🦜"
ALTERNATIVE_LOGO: false
APP_VERSION: "2.0"
FRONTEND_VERSION: "0.0.2"
ASSISTANT_VERSION: "0.0.3"

# Backend settings
UNAUTHORIZED_USER_REDIRECT_URL: "<your-url>"

# Parsing settings
PARSER_BACKEND: "kreuzberg"
KREUZBERG_URL: "http://kreuzberg-full:8000"
KREUZBERG_TIMEOUT: 120.0

# Langfuse Settings (Optional - for LLM observability)
# Used by core service for tracing and monitoring
# SECRET_KEY: "<your-secret-key>"  # Use MUCGPT_CORE_LANGFUSE__SECRET_KEY env var for production
LANGFUSE:
  HOST: "<your-url>"
  SECRET_KEY: "<your-sk>"
  PUBLIC_KEY: "<your-pk>"

# MCP Settings (Model Context Protocol)
# Used by core service for external tool integration
MCP:
  SOURCES:
    "ki-muenchen":
      url: "http://mcpdoc-server:8088/sse"
      transport: "sse"
      forward_token: false
      group: "ki-münchen"
      descriptions:
        - name: "fetch_docs"
          description: "Loads information from a specific URL about ai in munich. Always provide the whole url. Not only the relative path."
        - name: "list_doc_sources"
          description: "Lists information sources about ai in munich. Provides a list of relevant URLs. Use fetch-docs then to retrieve relevant data from the relevant urls. "
      # ...

    # Example for custom headers to authenticate with MCP server via litellm proxy
    # authentication with litellm via Bearer
    # authentication with mcp server via basic auth
    "mcp-atlassian":
      url: "<your-mcp-url>"
      transport: "streamable_http"
      forward_token: true
      forward_auth_override: "Basic <base64 encoded email:token>"
      headers:
        x-litellm-api-key: "<your-api-key>"
      group: "atlassian"
      # Example tool description overrides.
      descriptions:
        - name: "atlassianUserInfo"
          description: "Retrieve details about the currently authenticated Atlassian user (e.g. accountId). Use for user context or attribution."
        - name: "getAccessibleAtlassianResources"
          description: "Resolve available Atlassian sites and their cloudIds (i.e. the url). Use when cloudId is unknown or a hostname-based guess fails."
      # ...
  CACHE_TTL: 123

# Models configuration
# Configure your LLM models here instead of using base64-encoded JSON in environment variables
# IMPORTANT: Replace placeholder values with your actual configuration
# Consider using environment variables for sensitive data like API keys
MODELS:
  - type: "OPENAI"
    llm_name: "<your-llm-name>"
    deployment: ""
    endpoint: "<your-endpoint>"
    api_key: "<your-sk>" # IMPORTANT: Replace with actual API key or use MUCGPT_CORE_MODELS env var
    api_version: ""
    model_info:
      auto_enrich_from_model_info_endpoint: true
      max_output_tokens: 16384
      max_input_tokens: 128000
      description: "<description>"
      input_cost_per_token: 0.00000009
      output_cost_per_token: 0.00000036
      supports_function_calling: true
      supports_reasoning: false
      supports_vision: true
      litellm_provider: "<provider>"
      inference_location: "<region>"
      knowledge_cut_off: "2024-07-01"

# Additional models can be added here as list items:
# - type: "AZURE"
#   llm_name: "<another-model>"
#   endpoint: "<another-endpoint>"
#   api_key: "<another-key>"
#   model_info:
#     # ... model info ...

# SSO Settings (Keycloak)
# Used by both core and assistant services for authentication
# ROLE: "lhm-ab-mucgpt-user"
# ROLE: "lhm-ab-mucgpt-user" is default, can be overridden here

# Redis Settings (Valkey in docker-compose)
# Used by both core and assistant services for caching
REDIS:
  HOST: "valkey"
  PORT: 6379
  USERNAME: "default"
  PASSWORD: "password"
